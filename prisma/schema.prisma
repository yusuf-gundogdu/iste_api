generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ─── Kimlik ───────────────────────────────────────────────────────────────
// Tek hesap, iki mod (müşteri / usta). Usta modu ProProfile varlığıyla açılır.

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

// ─── Katalog ─────────────────────────────────────────────────────────────
// Kategori → alt hizmet ağacı; gerekli kategorilerde marka uzmanlığı.

model Category {
  id                 String  @id @default(uuid())
  slug               String  @unique
  name               String
  icon               String // mobil taraftaki ikon anahtarı
  sortOrder          Int     @default(0)
  requiresBrandModel Boolean @default(false)

  subServices SubService[]
  brands      Brand[]

  @@map("categories")
}

model SubService {
  id         String @id @default(uuid())
  categoryId String
  slug       String @unique
  name       String
  sortOrder  Int    @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("sub_services")
}

model Brand {
  id         String @id @default(uuid())
  categoryId String
  name       String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@map("brands")
}

model OtpCode {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
