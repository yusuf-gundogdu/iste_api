generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ─── Kimlik ───────────────────────────────────────────────────────────────
// Tek hesap, iki mod (müşteri / usta). Usta modu ProProfile varlığıyla açılır.

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens         RefreshToken[]
  proProfile            ProProfile?
  customerConversations Conversation[] @relation("customerConversations")
  sentMessages          Message[]      @relation("sentMessages")
  reviews               Review[]       @relation("customerReviews")
  favorites             Favorite[]
  addresses             Address[]
  notifications         Notification[]

  @@map("users")
}

// ─── Usta vitrini ────────────────────────────────────────────────────────
// Tek hesap iki mod: ProProfile varlığı usta modunu açar.
// Doğrulanmadan (VERIFIED) vitrin yayınlanamaz — anayasa kuralı.

enum VerificationStatus {
  MISSING
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum PriceApproach {
  NEGOTIABLE // fiyat konuşulur
  STARTING // başlangıç fiyatı ₺X
  FIXED // sabit hizmet ücreti ₺X
}

enum ServiceMode {
  ON_SITE // yerinde
  WORKSHOP // atölye
  BOTH
}

model ProProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  mainCategoryId     String
  coverUrl           String?
  bio                String             @default("")
  yearsExperience    Int?
  serviceMode        ServiceMode        @default(ON_SITE)
  priceApproach      PriceApproach      @default(NEGOTIABLE)
  priceAmount        Decimal?           @db.Decimal(10, 2)
  city               String             @default("")
  district           String             @default("")
  latitude           Float?
  longitude          Float?
  verificationStatus VerificationStatus @default(MISSING)
  isPublished        Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainCategory Category            @relation(fields: [mainCategoryId], references: [id])
  subServices  ProProfileSubService[]
  brands       ProProfileBrand[]
  regions      ProRegion[]
  workingHours  WorkingHour[]
  gallery       ProGalleryImage[]
  conversations Conversation[]
  reviews       Review[]
  favoritedBy   Favorite[]

  @@index([mainCategoryId])
  @@map("pro_profiles")
}

model ProGalleryImage {
  id           String   @id @default(uuid())
  proProfileId String
  url          String
  title        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)

  @@index([proProfileId])
  @@map("pro_gallery_images")
}

model ProProfileSubService {
  proProfileId String
  subServiceId String

  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)
  subService SubService @relation(fields: [subServiceId], references: [id], onDelete: Cascade)

  @@id([proProfileId, subServiceId])
  @@map("pro_profile_sub_services")
}

model ProProfileBrand {
  proProfileId String
  brandId      String

  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)
  brand      Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([proProfileId, brandId])
  @@map("pro_profile_brands")
}

model ProRegion {
  id           String @id @default(uuid())
  proProfileId String
  name         String // semt/bölge adı

  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)

  @@index([proProfileId])
  @@map("pro_regions")
}

model WorkingHour {
  id           String  @id @default(uuid())
  proProfileId String
  dayOfWeek    Int // 1 = Pazartesi … 7 = Pazar
  isOpen       Boolean @default(true)
  opensAt      String  @default("09:00")
  closesAt     String  @default("18:00")

  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)

  @@unique([proProfileId, dayOfWeek])
  @@map("working_hours")
}

// ─── Sohbet (ana omurga) ─────────────────────────────────────────────────
// Müşteri profilden mesaj başlatır; hizmet kaydı sohbetten türer (S11).

enum MessageType {
  TEXT
  IMAGE
  LOCATION
}

model Conversation {
  id            String   @id @default(uuid())
  customerId    String
  proProfileId  String
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  customer      User           @relation("customerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  proProfile    ProProfile     @relation(fields: [proProfileId], references: [id], onDelete: Cascade)
  messages      Message[]
  serviceRecord ServiceRecord?
  payments      Payment[]

  @@unique([customerId, proProfileId])
  @@index([proProfileId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  body           String      @default("")
  imageUrl       String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime    @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Hizmet kaydı (sohbetten türeyen ikincil kayıt) ──────────────────────
// UI'da ön planda değildir; sohbet ana yüzeydir. Statü her yüzeyde aynı
// gösterilir (anayasa: çelişki yok).

enum ServiceStatus {
  DISCUSSING // görüşülüyor
  PAYMENT_PENDING // ödeme bekleniyor
  SCHEDULED // planlandı
  IN_PROGRESS // devam ediyor
  COMPLETED // tamamlandı
  CANCELLED // iptal edildi
}

model ServiceRecord {
  id             String        @id @default(uuid())
  conversationId String        @unique
  status         ServiceStatus @default(DISCUSSING)
  title          String?
  agreedAmount   Decimal?      @db.Decimal(10, 2)
  scheduledAt    DateTime?
  address        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  payments     Payment[]
  review       Review?

  @@map("service_records")
}

// ─── Güvenli ödeme (escrow — opsiyonel güven katmanı) ────────────────────
// Para korumalı havuzda bekler; hizmet onaylanınca ustaya aktarılır.
// Komisyon %2, ustadan kesilir. Cüzdan/bakiye kavramı YOK.

enum PaymentStatus {
  REQUESTED // usta ödeme talebi oluşturdu
  PROCESSING // müşteri 3DS akışında
  SECURED // ödeme alındı, güvencede
  RELEASED // hizmet onaylandı, ustaya aktarıldı
  FAILED // ödeme başarısız (paran çekilmedi)
  REFUND_REQUESTED // müşteri iade talebi girdi
  REFUNDED // iade edildi
  CANCELLED // talep iptal edildi
}

model Payment {
  id                String        @id @default(uuid())
  conversationId    String
  serviceRecordId   String
  requestedByUserId String // usta
  paidByUserId      String? // müşteri
  amount            Decimal       @db.Decimal(10, 2)
  commissionRate    Decimal       @default(0.02) @db.Decimal(5, 4)
  commissionAmount  Decimal       @db.Decimal(10, 2)
  netAmount         Decimal       @db.Decimal(10, 2)
  note              String?
  status            PaymentStatus @default(REQUESTED)
  providerRef       String? // sağlayıcı ödeme/işlem referansı
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  conversation  Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord  @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  events        PaymentEvent[]

  @@index([conversationId])
  @@map("payments")
}

/// İşlem durumu zaman çizgisi (anayasa: ödeme detayında görünür).
model PaymentEvent {
  id        String        @id @default(uuid())
  paymentId String
  status    PaymentStatus
  note      String?
  createdAt DateTime      @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_events")
}

// ─── Değerlendirme / güven sistemi ───────────────────────────────────────
// Uygulama içi ödemeli işlem = doğrulanmış yorum (güçlü); yalnız görüşme
// sonrası = zayıf. Bir hizmet kaydına bir yorum.

model Review {
  id              String   @id @default(uuid())
  serviceRecordId String   @unique
  proProfileId    String
  customerId      String
  rating          Int // 1-5
  communication   Int? // alt puanlar 1-5
  punctuality     Int?
  workmanship     Int?
  body            String   @default("")
  isVerified      Boolean  @default(false) // uygulama içi ödeme ile doğrulandı
  proReply        String?
  repliedAt       DateTime?
  createdAt       DateTime @default(now())

  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  proProfile    ProProfile    @relation(fields: [proProfileId], references: [id], onDelete: Cascade)
  customer      User          @relation("customerReviews", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([proProfileId, createdAt])
  @@map("reviews")
}

// ─── Favoriler & Adresler ────────────────────────────────────────────────

model Favorite {
  userId       String
  proProfileId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)

  @@id([userId, proProfileId])
  @@map("favorites")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  title     String // Ev, İş…
  city      String
  district  String
  fullText  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ─── Bildirimler ─────────────────────────────────────────────────────────
// CTA'lı, ilgili yüzeye bağlanan bildirimler (anayasa RP5).

enum NotificationType {
  NEW_CONVERSATION
  PAYMENT_REQUESTED
  PAYMENT_SECURED
  PAYMENT_RELEASED
  REFUND_REQUESTED
  REVIEW_RECEIVED
  VERIFICATION_RESULT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Katalog ─────────────────────────────────────────────────────────────
// Kategori → alt hizmet ağacı; gerekli kategorilerde marka uzmanlığı.

model Category {
  id                 String  @id @default(uuid())
  slug               String  @unique
  name               String
  icon               String // mobil taraftaki ikon anahtarı
  sortOrder          Int     @default(0)
  requiresBrandModel Boolean @default(false)

  subServices SubService[]
  brands      Brand[]
  proProfiles ProProfile[]

  @@map("categories")
}

model SubService {
  id         String @id @default(uuid())
  categoryId String
  slug       String @unique
  name       String
  sortOrder  Int    @default(0)

  category    Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  proProfiles ProProfileSubService[]

  @@index([categoryId])
  @@map("sub_services")
}

model Brand {
  id         String @id @default(uuid())
  categoryId String
  name       String

  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  proProfiles ProProfileBrand[]

  @@unique([categoryId, name])
  @@map("brands")
}

model OtpCode {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
