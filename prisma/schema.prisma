generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ─── Kimlik ───────────────────────────────────────────────────────────────
// Tek hesap, iki mod (müşteri / usta). Usta modu ProProfile varlığıyla açılır.

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
