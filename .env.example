# İŞTE backend ortam değişkenleri (örnek). Gerçek değerler .env'de tutulur.
DATABASE_URL="postgresql://iste:iste_dev@localhost:5433/iste?schema=public"
JWT_SECRET="dev-secret-change-in-production"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
PORT=3010
UPLOAD_DIR="./uploads"

# ── iyzico Pazaryeri (ödeme) ────────────────────────────────────────────
# IYZICO_API_KEY tanımlıysa gerçek iyzico provider aktifleşir; boşsa
# geliştirmede FakePaymentProvider (mock 3DS) kullanılır.
# Sandbox anahtarları iyzico Sandbox hesabından (sandbox.iyzipay.com) alınır.
# IYZICO_API_KEY="sandbox-xxxxxxxxxxxxxxxxxxxxxxxx"
# IYZICO_SECRET="sandbox-xxxxxxxxxxxxxxxxxxxxxxxx"
# IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
#
# Sandbox TEST KARTLARI (iyzico):
#   Başarılı  : 5528790000000008 (Master)  · 4766620000000001 (Visa)
#   Başarısız : 5406670000000009 (yetersiz bakiye)
#   SKT: 12/30 · CVC: 123 · 3DS şifre: sandbox otomatik onaylar
